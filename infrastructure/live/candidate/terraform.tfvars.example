
# AWS Configuration
aws_region  = "us-west-2"
aws_profile = "sa-assessment"  # Profile configured with your candidate credentials

# Project
project_name   = "sa-assessment"
candidate_name = "your-name"  # Find this in the credentials info provided to you 

# Networking — Find these in the credentials info provided to you
vpc_id = "vpc-xxxxxxxxxxxxxxxxx"

public_subnet_ids = [
  "subnet-xxxxxxxxxxxxxxxxx",  # Public subnet AZ1
  "subnet-xxxxxxxxxxxxxxxxx",  # Public subnet AZ2
]

private_subnet_ids = [
  "subnet-xxxxxxxxxxxxxxxxx",  # Private subnet AZ1
  "subnet-xxxxxxxxxxxxxxxxx",  # Private subnet AZ2
]

# ECR — Find this in the credentials info provided to you
ecr_repository_url = "888577066340.dkr.ecr.us-west-2.amazonaws.com/nmd-sa-your-name"

# Database — provided in your credentials (or construct from RDS endpoint + password)
database_url = "postgresql+asyncpg://postgres:<password>@<rds-endpoint>:5432/sa_assessment"
